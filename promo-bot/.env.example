# Token del bot, creado con @BotFather.
# Consejo: creá DOS bots — uno de PRODUCCIÓN (va en Railway) y uno de PRUEBA (va en tu .env local).
# El mismo token no puede correr en dos lados a la vez (Telegram tira error 409 Conflict).
BOT_TOKEN=

# Connection string de Postgres (Supabase → Settings → Database → Connection string / URI).
# Incluye la contraseña de la base. Va acá y en Variables de Railway; NUNCA se commitea.
DATABASE_URL=

# Chat ID de admin, para avisos internos (opcional)
ADMIN_CHAT_ID=
