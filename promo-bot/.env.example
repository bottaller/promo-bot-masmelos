# Token del bot, creado con @BotFather.
# Consejo: creá DOS bots — uno de PRODUCCIÓN (va en Railway) y uno de PRUEBA (va en tu .env local).
# El mismo token no puede correr en dos lados a la vez (Telegram tira error 409 Conflict).
BOT_TOKEN=

# Connection string de Postgres (Supabase → Settings → Database → Connection string / URI).
# Incluye la contraseña de la base. Va acá y en Variables de Railway; NUNCA se commitea.
DATABASE_URL=

# ID de la planilla de Google Sheets (ya creada, con pestañas ALTAS y BAJAS)
GOOGLE_SHEET_ID=1G_f9l5cfM-IlaOZntNlWNpNVG0YYQZ8caSxSowLnx5c

# Credenciales de la cuenta de servicio de Google, en una sola linea, en base64
# Generarla en Google Cloud Console > IAM > Cuentas de servicio > Claves > JSON
# y despues correr: base64 -w0 credenciales.json  (o certutil en Windows)
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=

# Chat ID de control de calidad, para avisos internos de errores (opcional)
ADMIN_CHAT_ID=
